#include Std/Array.xu
#include Std/Num.xu
#include Std/Reduce.xu

(MaxVal) => (Array.Rev (1 2))

// generate a list from 1 to MaxVal
(ArrayNow) => (Num.GenList (MaxVal))

// sum up a list
Total Sum From 1 To (Array.Expand (Array.Rev (MaxVal))) Is (Array.Expand (Array.Rev (Array.Head (Reduce.Sum (ArrayNow)))))
